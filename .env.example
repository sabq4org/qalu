# ── قاعدة بيانات qalu (قراءة/كتابة — Neon أو أي Postgres) ──────────
DATABASE_URL=postgresql://user:pass@host/qalu?sslmode=require

# ── أرشيف سبق (قراءة فقط!) ─────────────────────────────────────────
# أنشئ المستخدم في قاعدة سبق:
#   CREATE USER qalu_reader WITH PASSWORD '...';
#   GRANT SELECT ON articles TO qalu_reader;
SABQ_DATABASE_URL=postgresql://qalu_reader:pass@host/sabq?sslmode=require
SABQ_ARTICLE_BASE=https://sabq.org/article

# ── المصادقة (Auth.js) ──────────────────────────────────────────────
# توليد: openssl rand -base64 32
AUTH_SECRET=

# ── OpenAI (للـ worker + البحث الذكي) ───────────────────────────────
OPENAI_API_KEY=
# اختياري — نموذج فهم استعلام البحث (افتراضي gpt-4o-mini)
SEARCH_INTERPRET_MODEL=

# ── إعدادات الاستخراج ───────────────────────────────────────────────
EXTRACT_BATCH_SIZE=50
EXTRACT_SINCE_DAYS=90

# ── الموقع ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudflare Web Analytics (اختياري، بلا كوكيز) ───────────────────
# من Cloudflare Dashboard → Web Analytics → token الموقع
NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# ── نشر إكس @mathaqalu (اختياري — بدونها: تنزيل + intent) ──────────
# من Developer Portal → App → Keys and tokens (OAuth 1.0a)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── إبطال الكاش يدوياً (اختياري) ────────────────────────────────────
# POST /api/revalidate?secret=...
REVALIDATE_SECRET=

# ── تخزين الصور — Railway Bucket (S3-compatible، خاص) ───────────────
# من تبويب Credentials في البكت، أو «Variable References» على qalu-web.
# لا تضع المفاتيح في Git. إن انكشفت: Regenerate Credentials.
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# بديل بأسماء Railway التلقائية: ENDPOINT / REGION / BUCKET / ACCESS_KEY_ID / SECRET_ACCESS_KEY

# ── لإنشاء الأدمن (npm run seed:admin) ─────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
